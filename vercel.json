{
  "github": {
    "silent": true
  },
  "git": {
    "deploymentEnabled": {
      "dependabot/*": false
    }
  },
  "rewrites": [
    {
      "source": "/api/kleros/(.*)",
      "destination": "https://scout-api.kleros.link/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
